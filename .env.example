# ─── MODO ────────────────────────────────────────────────────────────────────
# "sim"   → simulação 24/7 sem corretora (começa aqui!)
# "demo"  → paper trading com corretora real mas dinheiro fictício
# "real"  → dinheiro real (só quando tiveres resultados positivos)
MODE=sim

# ─── BROKER (só necessário para MODE=demo ou MODE=real) ──────────────────────
# "alpaca" → Alpaca Markets (ações US, ETFs, cripto)
# "ibkr"   → Interactive Brokers (futuros, forex, mercados globais)
# "both"   → usa os dois
BROKER=alpaca

# ─── SIMULAÇÃO ───────────────────────────────────────────────────────────────
SIM_CAPITAL=1000           # capital fictício em €
SIM_TICK_MS=30000          # intervalo entre checks (30s = 2 req/min ao Yahoo)
MAX_POSITION_EUR=300       # máximo por posição
MAX_TOTAL_EUR=800          # máximo total investido em simultâneo
DAILY_LOSS_LIMIT_EUR=150   # para o bot se perder mais de X€/dia

# ─── FIREBASE ADMIN ──────────────────────────────────────────────────────────
# Gera em: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Guarda como: config/firebase-admin.json
FIREBASE_PROJECT_ID=tradeaisimulator-aebcd

# ─── ALPACA (para MODE=demo ou real) ─────────────────────────────────────────
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── IBKR (para MODE=demo ou real com BROKER=ibkr) ───────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT_DEMO=7497
IBKR_PORT_REAL=7496
IBKR_CLIENT_ID=1

# ─── TELEGRAM (opcional mas muito recomendado) ────────────────────────────────
# @BotFather no Telegram → /newbot → copia token
# https://api.telegram.org/bot<TOKEN>/getUpdates → copia chat id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── GROQ (para análise AI no bot) ───────────────────────────────────────────
GROQ_API_KEY=gsk_...
