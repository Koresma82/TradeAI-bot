# ─── MODO ────────────────────────────────────────────────────────────────────
# "sim"   → simulação 24/7 sem corretora (começa aqui!)
# "demo"  → paper trading com corretora real mas dinheiro fictício
# "real"  → dinheiro real (só quando tiveres resultados positivos)
MODE=sim

# ─── BROKER (só necessário para MODE=demo ou MODE=real) ──────────────────────
# "alpaca" → Alpaca Markets (ações US, ETFs, cripto)
# "ibkr"   → Interactive Brokers (futuros, forex, mercados globais)
# "both"   → usa os dois
BROKER=alpaca

# ─── SIMULAÇÃO ───────────────────────────────────────────────────────────────
SIM_CAPITAL=1000           # capital fictício em €
SIM_TICK_MS=30000          # intervalo entre checks (30s = 2 req/min ao Yahoo)
MAX_POSITION_EUR=300       # máximo por posição
MAX_TOTAL_EUR=800          # máximo total investido em simultâneo
DAILY_LOSS_LIMIT_EUR=150   # para o bot se perder mais de X€/dia

# ─── FIREBASE ADMIN ──────────────────────────────────────────────────────────
# Gera em: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Guarda como: config/firebase-admin.json
FIREBASE_PROJECT_ID=tradeaisimulator-aebcd

# ID do utilizador (copia da app: Definições → Copiar UID)
# Garante que o bot escreve onde a app lê
USER_UID=

# ─── ALPACA (para MODE=demo ou real) ─────────────────────────────────────────
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── BINANCE (opcional, SÓ CRYPTO, ordens REAIS) ─────────────────────────────
# A Binance não tem "paper" — só executa real. Em paper usa a Alpaca.
# Cria as chaves em Binance → API Management. Para testes, testnet.binance.vision
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
# BINANCE_BASE_URL=https://testnet.binance.vision   # descomenta para testnet

# ─── ROUTING DE BROKERS (opcional) ───────────────────────────────────────────
# Define que broker trata cada classe de ativo, por ordem de preferência.
# Se omitido, usa o default (crypto: alpaca→binance; etf/stock/commodity: alpaca).
# Exemplo para mandar TODA a crypto para a Binance e o resto para a Alpaca:
#   BROKER_ROUTING=crypto:binance; etf:alpaca; stock:alpaca; commodity:alpaca
BROKER_ROUTING=

# ─── IBKR (para MODE=demo ou real com BROKER=ibkr) ───────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT_DEMO=7497
IBKR_PORT_REAL=7496
IBKR_CLIENT_ID=1

# ─── TELEGRAM (opcional mas muito recomendado) ────────────────────────────────
# @BotFather no Telegram → /newbot → copia token
# https://api.telegram.org/bot<TOKEN>/getUpdates → copia chat id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── GROQ (para análise AI no bot) ───────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─── FONTES DE PREÇO NÃO-CRYPTO (commodities, ETFs, forex) ───────────────────
# TwelveData: fonte primária. Grátis tem orçamento diário (esgota); pay-as-you-go remove o limite.
TWELVEDATA_KEY=
TWELVEDATA_DAILY_BUDGET=700   # créditos/dia antes de parar (free tier)
# Stooq: desde MARÇO 2026 exige API key (deixou de funcionar grátis).
#   Obtém em: https://stooq.com/q/d/?s=spy.us&get_apikey (resolve o captcha, copia a apikey do link CSV).
#   Sem esta chave, o Stooq fica DESATIVADO e o backup passa a ser só o Yahoo.
STOOQ_APIKEY=
# Finnhub: backup principal dos não-crypto (forex/ETF/ação). Free 60 chamadas/min, sem cartão.
#   Cria a chave grátis em https://finnhub.io (regista com email → Dashboard → API key).
#   Nota: ações/ETF US em tempo real no free; forex pode ter atraso/limite conforme o plano.
FINNHUB_KEY=
FINNHUB_MAX_PER_CYCLE=8   # nº máx de símbolos por ciclo (folga no limite de 60/min)
FINNHUB_FOREX=0          # 1 = também tentar forex (OANDA:) — só funciona com plano PAGO do Finnhub

# ─── FIREBASE CREDENCIAL (Railway/Hetzner) ───────────────────────────────────
# Em vez do ficheiro config/firebase-admin.json, cola aqui o JSON COMPLETO numa linha
# (Railway → Variables → New Variable → cola o conteúdo do ficheiro descarregado)
FIREBASE_ADMIN_JSON=
